# Porta do servidor (Render injeta automaticamente em produção)
PORT=3001

# Chave secreta para os tokens JWT — troque por algo aleatório e seguro
JWT_SECRET=troque_esta_chave_por_algo_seguro

# Conexão do PostgreSQL (Neon) — OBRIGATÓRIO
# Copie a "Connection string" do painel do Neon. Exemplo:
# DATABASE_URL=postgresql://usuario:senha@ep-xxxx.us-east-2.aws.neon.tech/coradb?sslmode=require
DATABASE_URL=

NODE_ENV=development
